generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password_hash String? // null for OAuth users (Google)
  role          Role      @default(STUDENT)
  country       String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  enrollments     Enrollment[]
  bookings        CoachingBooking[]
  comments        Comment[]
  payments        Payment[]
  coupon_usages   CouponUsage[]
  lesson_progress LessonProgress[]
  timezone        String            @default("Africa/Douala")
}

enum Role {
  ADMIN
  STUDENT
}

// NextAuth required tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── COURSES ──────────────────────────────────────────

model Course {
  id            String       @id @default(cuid())
  title         String
  slug          String       @unique
  description   String       @db.Text
  thumbnail_url String?
  price_xaf     Float
  price_usd     Float
  price_eur     Float
  is_free       Boolean      @default(false)
  status        CourseStatus @default(DRAFT)
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  modules     Module[]
  enrollments Enrollment[]
  coupons     Coupon[]
  payments    Payment[]
}

enum CourseStatus {
  DRAFT
  PUBLISHED
}

model Module {
  id          String   @id @default(cuid())
  course_id   String
  title       String
  order_index Int
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  course  Course   @relation(fields: [course_id], references: [id], onDelete: Cascade)
  lessons Lesson[]
}

model Lesson {
  id                  String       @id @default(cuid())
  module_id           String
  title               String
  cloudflare_video_id String?
  duration_seconds    Int?
  is_preview          Boolean      @default(false)
  order_index         Int
  status              LessonStatus @default(DRAFT)
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt

  module   Module           @relation(fields: [module_id], references: [id], onDelete: Cascade)
  comments Comment[]
  progress LessonProgress[]
}

enum LessonStatus {
  DRAFT
  PUBLISHED
}

model LessonProgress {
  id           String   @id @default(cuid())
  user_id      String
  lesson_id    String
  completed_at DateTime @default(now())

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lesson_id], references: [id], onDelete: Cascade)

  @@unique([user_id, lesson_id])
}

model Enrollment {
  id          String   @id @default(cuid())
  user_id     String
  course_id   String
  enrolled_at DateTime @default(now())

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  course Course @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@unique([user_id, course_id])
}

model Comment {
  id         String        @id @default(cuid())
  lesson_id  String
  user_id    String
  parent_id  String?
  content    String        @db.Text
  status     CommentStatus @default(ACTIVE)
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt

  lesson  Lesson    @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("Replies", fields: [parent_id], references: [id])
  replies Comment[] @relation("Replies")
}

enum CommentStatus {
  ACTIVE
  DELETED
}

// ─── COACHING ─────────────────────────────────────────

model CoachingSessionType {
  id        String  @id @default(cuid())
  name      String
  duration  Int
  price_xaf Float
  price_usd Float
  price_eur Float
  active    Boolean @default(true)

  bookings CoachingBooking[]
}

model CoachingAvailability {
  id         String   @id @default(cuid())
  date       DateTime @db.Date // specific calendar date
  start_time String // "09:00"
  end_time   String // "17:00"
  active     Boolean  @default(true)
}

model CoachingBooking {
  id                String        @id @default(cuid())
  user_id           String
  session_type_id   String
  start_datetime    DateTime
  end_datetime      DateTime
  status            BookingStatus @default(PENDING)
  meet_join_url     String?
  intake_goal       String?       @db.Text
  intake_challenges String?       @db.Text
  currency_paid     String
  amount_paid       Float
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  user         User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  session_type CoachingSessionType @relation(fields: [session_type_id], references: [id])
  payment      Payment?
  timezone     String              @default("Africa/Douala")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

// ─── PAYMENTS ─────────────────────────────────────────

model Payment {
  id                 String        @id @default(cuid())
  user_id            String
  product_type       ProductType
  course_id          String? // set when product_type = COURSE
  booking_id         String?       @unique // set when product_type = COACHING
  amount             Float
  currency           String
  provider           String
  external_reference String?       @unique
  status             PaymentStatus @default(PENDING)
  created_at         DateTime      @default(now())
  updated_at         DateTime      @updatedAt

  user      User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  course    Course?          @relation(fields: [course_id], references: [id])
  booking   CoachingBooking? @relation(fields: [booking_id], references: [id])
  coupon_id String?
  coupon    Coupon?          @relation(fields: [coupon_id], references: [id])
}

enum ProductType {
  COURSE
  COACHING
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// ─── COUPONS ──────────────────────────────────────────

model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  discount_type DiscountType
  value         Float
  course_id     String? // null = applies to all courses
  expires_at    DateTime?
  max_uses      Int?
  uses_count    Int          @default(0)
  active        Boolean      @default(true)
  created_at    DateTime     @default(now())

  course   Course?       @relation(fields: [course_id], references: [id])
  usages   CouponUsage[]
  payments Payment[]
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model CouponUsage {
  id        String   @id @default(cuid())
  coupon_id String
  user_id   String
  used_at   DateTime @default(now())

  coupon Coupon @relation(fields: [coupon_id], references: [id])
  user   User   @relation(fields: [user_id], references: [id])

  @@unique([coupon_id, user_id])
}
